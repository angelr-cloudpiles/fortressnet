aws_region       = "us-east-1"
domain_name      = "fortressnet.app"
hosted_zone_name = "fortressnet.app"
app_subdomain    = "app"

app_image_tag = "clean-20260722-001"

desired_count           = 2
enable_nat_gateway      = true
database_instance_class = "db.t4g.micro"
waf_rate_limit          = 2000

# Optional. Terraform creates the topic without a subscription when empty.
alarm_email = ""

tags = {
  Owner = "angelr-cloudpiles"
}
